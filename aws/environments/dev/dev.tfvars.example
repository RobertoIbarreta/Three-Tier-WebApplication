# Copy to dev.tfvars (gitignored). Do not commit secrets.
# terraform plan -var-file=environments/dev/dev.tfvars

# ---------- Global ----------
project_name = "three-tier-webapp"
environment  = "dev"
owner        = "your-team-or-contact"
aws_region   = "us-east-1"

# ---------- Networking (non-overlapping CIDRs per env in same account) ----------
vpc_cidr             = "10.10.0.0/16"
public_subnet_cidrs  = ["10.10.1.0/24", "10.10.2.0/24"]
private_app_subnets  = ["10.10.11.0/24", "10.10.12.0/24"]
private_db_subnets   = ["10.10.21.0/24", "10.10.22.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]

# ---------- Compute / App Tier ----------
instance_type        = "t3.micro"
app_port             = 8080
app_health_check_path = "/health"
# app_bootstrap_extra_commands = <<-EOC
# echo "extra bootstrap commands here"
# EOC
asg_min_size         = 1
asg_desired_capacity = 1
asg_max_size         = 2

# ---------- Load Balancer ----------
alb_ingress_cidrs = ["0.0.0.0/0"]
health_check_path = "/health"

# ---------- Database Tier ----------
db_engine              = "mysql"
db_engine_version      = "8.0"
db_parameter_group_family = "mysql8.0"
db_instance_class      = "db.t3.micro"
db_allocated_storage   = 20
db_name                = "appdb"
db_username            = "app_user"
# db_password          = "replace-with-secure-secret" # Only needed if not using managed master password
db_port                = 3306
db_backup_retention    = 1
db_maintenance_window  = "Mon:03:00-Mon:04:00"
db_skip_final_snapshot = true
db_multi_az            = false
db_publicly_accessible = false
