# Copy to stage.tfvars (gitignored). Do not commit secrets.
# terraform plan -var-file=environments/stage/stage.tfvars

# ---------- Global ----------
project_name = "three-tier-webapp"
environment  = "stage"
owner        = "your-team-or-contact"
aws_region   = "us-east-1"

# ---------- Networking ----------
vpc_cidr             = "10.20.0.0/16"
public_subnet_cidrs  = ["10.20.1.0/24", "10.20.2.0/24"]
private_app_subnets  = ["10.20.11.0/24", "10.20.12.0/24"]
private_db_subnets   = ["10.20.21.0/24", "10.20.22.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]

# ---------- SSM Session Manager ----------
enable_ssm_vpc_endpoints = false

# ---------- Compute / App Tier ----------
instance_type        = "t3.small"
app_port             = 8080
app_health_check_path = "/health"
# app_bootstrap_extra_commands = <<-EOC
# echo "extra bootstrap commands here"
# EOC
asg_min_size         = 2
asg_desired_capacity = 2
asg_max_size         = 4
asg_target_requests_per_target = 100

# ---------- Load Balancer ----------
alb_ingress_cidrs = ["0.0.0.0/0"]
health_check_path = "/health"
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/your-real-cert-id"
enable_http_to_https_redirect = true
# enable_waf defaults to true; omit or set false only to save cost in non-prod.
# enable_aws_backup defaults to true (RDS in AWS Backup; set false to use RDS automated backups only).

# ---------- Route53 (existing public hosted zone) ----------
# route53_zone_id = "Z1234567890ABC"
# api_dns_name    = "api.example.com"

# ---------- Presentation Tier ----------
frontend_domain_name         = null
frontend_acm_certificate_arn = null
frontend_index_document      = "index.html"
frontend_error_document      = "index.html"
backend_allowed_origins      = ["https://example-frontend-domain.cloudfront.net"]

# ---------- Database Tier ----------
db_engine              = "mysql"
db_engine_version      = "8.0"
db_parameter_group_family = "mysql8.0"
db_instance_class      = "db.t3.small"
db_allocated_storage   = 20
db_name                = "appdb"
db_username            = "app_user"
# db_password          = "replace-with-secure-secret" # Only needed if not using managed master password
db_port                = 3306
db_backup_retention    = 3
db_maintenance_window  = "Tue:03:00-Tue:04:00"
db_skip_final_snapshot = false
db_multi_az            = true
db_publicly_accessible = false

# ---------- Observability ----------
# Defaults enable ALB access logs and CloudWatch alarms; tune per team.
# cloudwatch_alarm_sns_topic_arns = ["arn:aws:sns:us-east-1:123456789012:your-topic"]
# alb_access_logs_retention_days = 60
# cloudwatch_alarm_alb_5xx_threshold = 25
