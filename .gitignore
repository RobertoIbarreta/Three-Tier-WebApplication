# Local .terraform directories
.terraform/
**/.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Ignore all Terraform variable files (often secrets), keep examples
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
!*.tfvars.example
!*.auto.tfvars.example

# Explicit local env files for this repo layout
aws/*.tfvars
aws/bootstrap/*.tfvars
aws/environments/*/*.tfvars
aws/environments/*/backend.hcl
gcp/*.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Terraform plan artifacts
*.tfplan
*.plan

# Keep lock file committed by default (recommended).
# Uncomment ONLY if your team policy is to not commit provider locks.
# .terraform.lock.hcl
